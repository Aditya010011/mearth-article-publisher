<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= config.site.name %> Article Publisher - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .resource-item { border: 1px solid #e2e8f0; padding: 1rem; margin-bottom: 1rem; border-radius: 0.5rem; }
    .file-drop-zone { border: 2px dashed #cbd5e0; background: #f7fafc; min-height: 150px; }
    .file-drop-zone.dragover { background: #e6fffa; border-color: #38b2ac; }
  </style>
</head>
<body class="bg-gray-50">
  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-6">
      <h1 class="text-3xl font-bold text-gray-800"><%= config.site.name %> Article Publisher</h1>
      <p class="text-gray-600 mt-2"><%= config.site.tagline %></p>
      <div class="mt-4 flex gap-4">
        <button onclick="exportArticles()" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded">
          📦 Export All for Upload
        </button>
        <button onclick="viewArticles()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">
          📋 View Published Articles
        </button>
      </div>
    </div>

    <!-- Step 1: Upload Files -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-6">
      <h2 class="text-2xl font-bold text-gray-800 mb-4">Step 1: Upload Files</h2>
      
      <form id="uploadForm" enctype="multipart/form-data">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Word Document (Required)</label>
            <input type="file" name="docx" accept=".docx" required class="w-full border rounded p-2">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">PDF (Required)</label>
            <input type="file" name="pdf" accept=".pdf" required class="w-full border rounded p-2">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Featured Image (Required)</label>
            <input type="file" name="image" accept="image/*" required class="w-full border rounded p-2">
          </div>
        </div>
        
        <button type="submit" class="mt-4 bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded">
          Parse Document
        </button>
      </form>
      
      <div id="parseStatus" class="mt-4 hidden"></div>
    </div>

    <!-- Step 2: Review & Edit (Hidden until parsing complete) -->
    <div id="editorSection" class="hidden">
      <form id="articleForm">
        <!-- Core Content -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <h2 class="text-2xl font-bold text-gray-800 mb-4">Step 2: Review & Edit Content</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Title</label>
              <input type="text" id="title" name="title" required class="w-full border rounded p-2">
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Subtitle (Optional)</label>
              <input type="text" id="subtitle" name="subtitle" class="w-full border rounded p-2">
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Body (HTML)</label>
              <p class="text-sm text-gray-500 mb-2">Plain textarea - edit HTML directly. For major changes, edit the source Word document.</p>
              <textarea id="body" name="body" rows="15" required class="w-full border rounded p-2 font-mono text-sm"></textarea>
              <p class="text-sm text-gray-500 mt-1">Word count: <span id="wordCount">0</span> | Read time: <span id="readTime">0</span> min</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Author</label>
                <select id="author_id" name="author_id" class="w-full border rounded p-2">
                  <% authors.forEach(author => { %>
                    <option value="<%= author.id %>" <%= author.is_default ? 'selected' : '' %>>
                      <%= author.full_name %>
                    </option>
                  <% }); %>
                </select>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Publish Date</label>
                <input type="date" id="publish_date" name="publish_date" class="w-full border rounded p-2" value="<%= new Date().toISOString().split('T')[0] %>">
              </div>
            </div>
          </div>
        </div>

        <!-- Primary & Secondary Categories -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">Categories</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Primary Category (Required)</label>
              <select id="primary_category" name="primary_category" required class="w-full border rounded p-2">
                <option value="">-- Select Primary Category --</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat.id %>"><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Secondary Category (Optional)</label>
              <select id="secondary_category" name="secondary_category" class="w-full border rounded p-2">
                <option value="">-- None --</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat.id %>"><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>

        <!-- PMH Zones -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">PMH Classification Zones (Select Any)</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
            <% pmhZones.forEach(zone => { %>
              <label class="flex items-center space-x-2">
                <input type="checkbox" name="pmh_zones" value="<%= zone.id %>" class="rounded">
                <span class="text-sm"><%= zone.number %>. <%= zone.name %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <!-- MegaChallenges -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">MegaChallenges (Select Any)</h3>
          <p class="text-sm text-gray-600 mb-4">Six interconnected challenges - no ranking implied</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            <% megaChallenges.forEach(challenge => { %>
              <label class="flex items-center space-x-2">
                <input type="checkbox" name="mega_challenges" value="<%= challenge.id %>" class="rounded">
                <span class="text-sm"><%= challenge.name %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <!-- Topics -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-bold text-gray-800">Topics (Select 2-5)</h3>
            <button type="button" onclick="addNewTopic()" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">
              + Add New Topic
            </button>
          </div>
          <div id="topicsGrid" class="grid grid-cols-2 md:grid-cols-4 gap-2">
            <% topics.forEach(topic => { %>
              <label class="flex items-center space-x-2">
                <input type="checkbox" name="topics" value="<%= topic.id %>" class="rounded">
                <span class="text-sm"><%= topic.name %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <!-- Entities -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">Entity Associations (Select Any)</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            <% entities.forEach(entity => { %>
              <label class="flex items-center space-x-2">
                <input type="checkbox" name="entities" value="<%= entity.id %>" class="rounded">
                <span class="text-sm"><%= entity.name %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <!-- Additional Resources -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">Additional Resources (Optional)</h3>
          <p class="text-sm text-gray-600 mb-4">Add supplementary PDFs, graphics, video links, or external references</p>

          <div id="resourcesContainer"></div>

          <button type="button" onclick="addResource()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded">
            + Add Resource
          </button>
        </div>

        <!-- SEO & Contact (Optional) -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">SEO & Contact Information (Optional)</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Meta Description (160 chars)</label>
              <textarea id="meta_description" name="meta_description" rows="2" maxlength="160"
                class="w-full border rounded p-2" placeholder="Auto-generated from first paragraph if blank"></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Contact Information</label>
              <textarea id="contact_info" name="contact_info" rows="2"
                class="w-full border rounded p-2"
                placeholder="Default: <%= config.site.contact_text %>"></textarea>
              <p class="text-xs text-gray-500 mt-1">Leave blank to use default contact info. Add custom text to override.</p>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <div class="flex gap-4">
            <button type="button" onclick="previewArticle()" class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded">
              👁️ Preview
            </button>
            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded">
              ✓ Generate & Export
            </button>
          </div>
          <div id="generateStatus" class="mt-4"></div>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/admin.js"></script>
</body>
</html>
